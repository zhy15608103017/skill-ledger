#!/usr/bin/env node
import { spawnSync } from "node:child_process";
import { stdin } from "node:process";
import { dirname, resolve } from "node:path";
import { fileURLToPath } from "node:url";

import { buildBootstrapText, readStartupSkillText } from "../core/bootstrap.mjs";
import { appendEvent } from "../core/audit-log.mjs";

const hookDir = dirname(fileURLToPath(import.meta.url));
const pluginRoot = resolve(hookDir, "..");
const payload = parseJson(await readStdin());
const harness = process.env.SKILL_LEDGER_HARNESS || detectHarness();
const cwd = process.env.SKILL_LEDGER_CWD || stringValue(payload.cwd) || process.cwd();
const sessionId = observedSessionId(payload);

try {
  const start = startAuditRun();
  const skillText = await readStartupSkillText(pluginRoot);
  const bootstrap = buildBootstrapText({
    runId: start.runId,
    pluginRoot,
    logFile: start.logFile,
    harness,
    sessionId,
    skillText,
  });
  await appendEvent(start.logFile, {
    event: "skill_called",
    runId: start.runId,
    skill: "using-skill-audit",
    evidence: "context_observed",
    reason: `${displayHarnessName(harness)} session hook injected using-skill-audit Skill content`,
  });

  process.stdout.write(`${JSON.stringify(payloadForHarness(bootstrap), null, 2)}\n`);
} catch (error) {
  process.stderr.write(`${error.stack || error.message}\n`);
  process.exit(1);
}

function startAuditRun() {
  const args = [resolve(pluginRoot, "scripts", "skill-ledger.mjs"), "start", "--harness", harness, "--cwd", cwd];
  if (sessionId) args.push("--session-id", sessionId);
  const taskContext = observedTaskContext(payload);
  if (taskContext) args.push("--task-context-stdin");
  const result = spawnSync(
    process.execPath,
    args,
    {
      cwd,
      encoding: "utf8",
      input: taskContext || undefined,
      env: process.env,
    },
  );

  if (result.status !== 0) {
    throw new Error(result.stderr || result.stdout || "Failed to start Skill Ledger audit run.");
  }

  return JSON.parse(result.stdout);
}

function readStdin() {
  return new Promise((resolvePromise, reject) => {
    let content = "";
    stdin.setEncoding("utf8");
    stdin.on("data", (chunk) => { content += chunk; });
    stdin.on("end", () => resolvePromise(content));
    stdin.on("error", reject);
  });
}

function parseJson(content) {
  const text = String(content || "").trim();
  if (!text) return {};
  try { return JSON.parse(text); } catch { return {}; }
}

function observedSessionId(value) {
  return stringValue(
    process.env.SKILL_LEDGER_SESSION_ID ||
    value.session_id || value.sessionId || value.conversation_id || value.conversationId ||
    value.thread_id || value.threadId || value.transcript_path || value.transcriptPath,
  );
}

function observedTaskContext(value) {
  return stringValue(value.prompt || value.user_prompt || value.userPrompt || value.message || value.input?.prompt).slice(0, 4000);
}

function stringValue(value) {
  if (value === undefined || value === null || typeof value === "object") return "";
  return String(value).trim();
}

function payloadForHarness(bootstrap) {
  if (harness === "cursor") {
    return { additional_context: bootstrap };
  }

  if (harness === "claude-code") {
    return {
      hookSpecificOutput: {
        hookEventName: "SessionStart",
        additionalContext: bootstrap,
      },
    };
  }

  return { additionalContext: bootstrap };
}

function detectHarness() {
  if (isCodexEnvironment()) return "codex";
  if (process.env.CURSOR_PLUGIN_ROOT) return "cursor";
  if (process.env.COPILOT_CLI) return "copilot-cli";
  if (process.env.CLAUDE_PLUGIN_ROOT) return "claude-code";
  return "shell-hook";
}

function isCodexEnvironment() {
  return Boolean(
    process.env.CODEX_THREAD_ID ||
    process.env.CODEX_INTERNAL_ORIGINATOR_OVERRIDE ||
    process.env.CODEX_SHELL ||
    process.env.CODEX_CI,
  );
}

function displayHarnessName(value) {
  const names = { codex: "Codex", "claude-code": "Claude Code", cursor: "Cursor", "copilot-cli": "GitHub Copilot CLI" };
  return names[value] || value || "unknown";
}
